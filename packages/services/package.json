{
  "name": "@repo/services",
  "version": "0.1.0",
  "private": true,
  "description": "Hexagonal adapter implementations for email, CRM, analytics, and payments ports",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./email": "./src/email/index.ts",
    "./email/factory": "./src/email/factory.ts",
    "./crm": "./src/crm/index.ts",
    "./crm/factory": "./src/crm/factory.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/service-ports": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "resend": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "resend": {
      "optional": true
    }
  }
}
